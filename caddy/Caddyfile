# Proxy inverso con HTTPS automático (Let's Encrypt). Caddy obtiene y RENUEVA los
# certificados solo (necesita los puertos 80 y 443 accesibles desde internet y que los
# dominios resuelvan a este servidor). Dominios y email salen del .env.
#
#   APP_DOMAIN      -> la web pública (SPA + /api + /media, vía el nginx del frontend)
#   SANDBOX_DOMAIN  -> origen AISLADO de los ejercicios (subdominio distinto, CLAUDE.md §10)

{
	email {$ACME_EMAIL}
}

# --- Web pública ---
{$APP_DOMAIN} {
	encode zstd gzip
	header {
		# HSTS y cabeceras de seguridad para el origen de la app.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	reverse_proxy frontend:80
}

# --- Origen sandbox (ejercicios interactivos) ---
# El nginx del sandbox define su propia CSP estricta; aquí solo se proxya, sin tocarla.
{$SANDBOX_DOMAIN} {
	encode zstd gzip
	reverse_proxy sandbox:80
}

# --- Paneles de administración del servidor (OPCIONAL) ---
# Proxy inverso a herramientas que corren FUERA de este stack, para servirlas por HTTPS con
# un subdominio en lugar de su puerto (y poder cerrar esos puertos a internet). Ambas hablan
# HTTPS con certificado AUTOFIRMADO en su puerto, por eso se omite la verificación TLS interna:
# el cifrado de cara a internet lo pone Caddy con su certificado de Let's Encrypt.
#
#   WEBMIN_DOMAIN     -> Webmin (en el HOST, puerto 10000)
#   PORTAINER_DOMAIN  -> Portainer (contenedor que PUBLICA el 9443 en el host)
#
# `host.docker.internal` apunta al host (requiere el extra_hosts del docker-compose). Si NO
# defines el dominio en el .env, docker-compose pasa un valor *.localhost: Caddy lo sirve con
# un certificado interno (NO lo pide a Let's Encrypt) y el bloque queda inerte, sin uso.
{$WEBMIN_DOMAIN} {
	reverse_proxy https://host.docker.internal:10000 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

{$PORTAINER_DOMAIN} {
	reverse_proxy https://host.docker.internal:9443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}
