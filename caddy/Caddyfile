# Proxy inverso con HTTPS automático (Let's Encrypt). Caddy obtiene y RENUEVA los
# certificados solo (necesita los puertos 80 y 443 accesibles desde internet y que los
# dominios resuelvan a este servidor). Dominios y email salen del .env.
#
#   APP_DOMAIN      -> la web pública (SPA + /api + /media, vía el nginx del frontend)
#   SANDBOX_DOMAIN  -> origen AISLADO de los ejercicios (subdominio distinto, CLAUDE.md §10)

{
	email {$ACME_EMAIL}
}

# --- Web pública ---
{$APP_DOMAIN} {
	encode zstd gzip
	header {
		# HSTS y cabeceras de seguridad para el origen de la app.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	reverse_proxy frontend:80
}

# --- Origen sandbox (ejercicios interactivos) ---
# El nginx del sandbox define su propia CSP estricta; aquí solo se proxya, sin tocarla.
{$SANDBOX_DOMAIN} {
	encode zstd gzip
	reverse_proxy sandbox:80
}

# --- Paneles de administración del servidor (OPCIONAL) ---
# Proxy inverso a herramientas que corren FUERA de este stack, para servirlas por HTTPS con
# un subdominio en lugar de su puerto (y poder cerrar esos puertos a internet). Si NO defines
# el dominio en el .env, docker-compose pasa un valor *.localhost: Caddy lo sirve con un
# certificado interno (NO lo pide a Let's Encrypt) y el bloque queda inerte, sin uso.
#
#   WEBMIN_DOMAIN     -> Webmin (proceso del HOST, puerto 10000)
#   PORTAINER_DOMAIN  -> Portainer (contenedor)

# Webmin corre en el HOST: se alcanza por host.docker.internal:10000 (requiere el extra_hosts
# del docker-compose). Habla HTTPS con cert autofirmado, por eso se omite la verificación TLS
# interna (tls_insecure_skip_verify); el cifrado de cara a internet lo pone Caddy con Let's Encrypt.
# NOTA Webmin (en el HOST, /etc/webmin/, una sola vez): para que no de "Trusted Referrers" ni
# obligue a recargar, en /etc/webmin/miniserv.conf -> redirect_ssl=1, y en /etc/webmin/config ->
# referers=<tu webmin.dominio> host.docker.internal ; luego systemctl restart webmin.
#
# header_up Host {host}: imprescindible para el TERMINAL de Webmin (WebSocket). Webmin valida el
# Origin del navegador (https://webmin.<dominio>) contra el Host que recibe; sin reescribirlo le
# llega host.docker.internal:10000 -> no coinciden -> rechaza el handshake y el terminal se queda
# en "CONNECTING...". (Mismo problema que el "origin invalid" de Portainer.) Solo cambia la cabecera
# Host; Caddy sigue conectando por TCP a host.docker.internal:10000 (con tls_insecure el SNI da igual).
{$WEBMIN_DOMAIN} {
	reverse_proxy https://host.docker.internal:10000 {
		transport http {
			tls_insecure_skip_verify
			# El terminal de Webmin usa WebSocket (RFC 6455), que requiere HTTP/1.1. Sobre un
			# upstream HTTPS Caddy podría negociar otra versión y el upgrade se cae (la conexión
			# acaba como "Finished"/0 B en vez de "101 Switching Protocols"). Forzar 1.1 lo arregla.
			versions 1.1
		}
		header_up Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
	}
}

# Portainer corre como CONTENEDOR. NO se usa host.docker.internal:9443 a propósito: por ahí
# Portainer recibiría un Host interno y su protección CSRF rechazaría las acciones de escritura
# ("Forbidden - origin invalid"); además el doble TLS lo hace más lento. En su lugar se le habla
# por la RED INTERNA del stack, por NOMBRE de contenedor y por su puerto HTTP (9000), forzando el
# Host público con header_up. Requiere conectar UNA vez el contenedor 'portainer' a la red de este
# stack:  ./connect-portainer.sh  (Portainer es externo al compose y no se puede declarar aquí).
{$PORTAINER_DOMAIN} {
	reverse_proxy portainer:9000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto https
	}
}
