{
  "name": "plataforma-educativa-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "fetch-schema": "curl -s http://localhost:8001/openapi.json -o openapi.json",
    "generate-api": "openapi-typescript openapi.json -o src/shared/api/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.2",
    "openapi-fetch": "^0.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "openapi-typescript": "^7.4.1",
    "typescript": "^5.5.4",
    "vite": "^4.5.5"
  }
}
