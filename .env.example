# Copia este fichero a .env y ajústalo. NUNCA subas .env al repositorio.
# --- Dominios ---
APP_DOMAIN=app.midominio.es
API_DOMAIN=api.midominio.es
SANDBOX_DOMAIN=sandbox.midominio.es
# --- Backend ---
DATABASE_URL=sqlite:///./data/app.sqlite3
MEDIA_DIR=./media
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
LOG_LEVEL=INFO
# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173
