# Copia este fichero a .env y ajústalo. NUNCA subas .env al repositorio.
# --- Dominios ---
APP_DOMAIN=app.midominio.es
API_DOMAIN=api.midominio.es
SANDBOX_DOMAIN=sandbox.midominio.es
# --- Backend ---
DATABASE_URL=sqlite:///./data/app.sqlite3
MEDIA_DIR=./media
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
LOG_LEVEL=INFO
# --- Sandbox (origen aislado de ejercicios interactivos, §10) ---
# Origen público desde el que se sirven los HTML. En dev: la app Python en :8002.
# En prod: https://sandbox.midominio.es
SANDBOX_BASE_URL=http://localhost:8002
# Orígenes de la app autorizados a embeber el iframe (CSP frame-ancestors).
APP_ORIGINS=http://localhost:5173
# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173
