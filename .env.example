# Copia este fichero a .env y ajústalo. NUNCA subas .env al repositorio.
#
# === SERVIDOR DE PRUEBAS (Docker) ===
# Sustituye TU_SERVIDOR por la IP o el dominio del servidor (p. ej. 192.168.1.50 o pruebas.midominio.es).
# Los puertos deben coincidir con los publicados en docker-compose.yml:
#   frontend 5173 · api 5070 · sandbox 5071
#
# El navegador carga los ejercicios desde el sandbox: esta URL debe ser ALCANZABLE DESDE EL NAVEGADOR.
SANDBOX_BASE_URL=http://TU_SERVIDOR:5071
# Origen del frontend autorizado a embeber el iframe del sandbox (CSP frame-ancestors) y CORS.
# Usa un único origen (sin barra final). Debe ser el del frontend: http://TU_SERVIDOR:5173
APP_ORIGINS=http://TU_SERVIDOR:5173
CORS_ALLOW_ORIGINS=http://TU_SERVIDOR:5173

# === Backend ===
DATABASE_URL=sqlite:///./data/app.sqlite3
MEDIA_DIR=./media
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Admin inicial (se crea automáticamente si la BD no tiene usuarios) ===
DEFAULT_ADMIN_EMAIL=admin@plataforma.local
DEFAULT_ADMIN_PASSWORD=CambiaMe1234
