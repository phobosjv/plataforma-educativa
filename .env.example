# Copia este fichero a .env y ajústalo. NUNCA subas .env al repositorio.
#
# === PRODUCCIÓN (Docker + Caddy + HTTPS automático) ===
# Caddy obtiene los certificados de Let's Encrypt para estos dos dominios. Requisitos:
#   - Registros DNS A de AMBOS dominios apuntando a la IP pública del servidor.
#   - Puertos 80 y 443 redirigidos del router al servidor.
#
# Dominio de la WEB pública:
APP_DOMAIN=plataforma.tudominio.com
# Subdominio del SANDBOX (origen aislado de los ejercicios; debe ser distinto al de la app):
SANDBOX_DOMAIN=sandbox.tudominio.com
# Email para Let's Encrypt (avisos de caducidad):
ACME_EMAIL=tu-email@tudominio.com

# NOTA: SANDBOX_BASE_URL, APP_ORIGINS y CORS_ALLOW_ORIGINS se derivan automáticamente de
# APP_DOMAIN/SANDBOX_DOMAIN en docker-compose.yml (https://…). No hace falta ponerlos aquí.

# --- (OPCIONAL) Paneles de administración del servidor servidos por HTTPS vía Caddy ---
# Si gestionas el servidor con Webmin y/o Portainer, define aquí sus subdominios y Caddy
# obtendrá su certificado y hará de proxy inverso (tú entras por https://… sin el puerto, y
# puedes cerrar 10000/9443 a internet). Requisitos por subdominio: registro DNS A apuntando
# a este servidor. Webmin debe correr en el HOST (puerto 10000); Portainer debe ser un
# contenedor que PUBLIQUE el 9443 en el host. Déjalos comentados/sin definir si no los usas.
# WEBMIN_DOMAIN=webmin.tudominio.com
# PORTAINER_DOMAIN=portainer.tudominio.com

# === Backend ===
DATABASE_URL=sqlite:///./data/app.sqlite3
MEDIA_DIR=./media
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=production
LOG_LEVEL=INFO

# === Admin inicial (se crea automáticamente si la BD no tiene usuarios) ===
DEFAULT_ADMIN_EMAIL=admin@plataforma.local
DEFAULT_ADMIN_PASSWORD=CambiaMe1234

# === Copias de seguridad de la BD (tarea en segundo plano) ===
# Copia en caliente del SQLite + rotación (conserva las BACKUP_KEEP más recientes).
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=7
# Copia incremental de la carpeta media (ejercicios + imágenes) junto a la de la BD.
MEDIA_BACKUP_ENABLED=true

# === Purga programada de la papelera ===
# El contenido borrado (lógico) durante más de TRASH_RETENTION_DAYS se elimina DEFINITIVAMENTE.
# Pon TRASH_PURGE_ENABLED=false (o TRASH_RETENTION_DAYS=0) para desactivar la purga automática.
TRASH_PURGE_ENABLED=true
TRASH_RETENTION_DAYS=30
TRASH_PURGE_INTERVAL_HOURS=24
