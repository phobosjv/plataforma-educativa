# Copia este fichero a .env y ajústalo. NUNCA subas .env al repositorio.
#
# === SERVIDOR DE PRUEBAS (Docker) ===
# Puertos publicados (deben coincidir con docker-compose.yml): frontend 5173 · api 5070 · sandbox 5071
#
# Puedes acceder por IP Y por dominio a la vez (el frontend lo sirve nginx, que acepta cualquier
# Host). En los ejemplos:
#   IP      = 192.168.1.50      (acceso en la red local)
#   DOMINIO = phobosjv.ddns.net (acceso externo)
# Sustituye por tus valores reales.

# Origen aislado de los ejercicios: el navegador lo carga directamente, así que debe ser
# alcanzable desde donde abras la web. Es UN único valor; usa el dominio si accedes desde fuera
# (suele funcionar también en la LAN si el router hace NAT hairpin). Si solo pruebas en la LAN, usa la IP.
SANDBOX_BASE_URL=http://phobosjv.ddns.net:5071

# Orígenes del frontend autorizados a embeber el iframe del sandbox (CSP frame-ancestors).
# Admite VARIOS, separados por ESPACIOS, sin barra final.
APP_ORIGINS=http://phobosjv.ddns.net:5173 http://192.168.1.50:5173

# Orígenes permitidos para CORS de la API. Admite VARIOS, separados por COMAS.
CORS_ALLOW_ORIGINS=http://phobosjv.ddns.net:5173,http://192.168.1.50:5173

# === Backend ===
DATABASE_URL=sqlite:///./data/app.sqlite3
MEDIA_DIR=./media
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Admin inicial (se crea automáticamente si la BD no tiene usuarios) ===
DEFAULT_ADMIN_EMAIL=admin@plataforma.local
DEFAULT_ADMIN_PASSWORD=CambiaMe1234
