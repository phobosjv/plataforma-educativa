# Los scripts de shell y los ficheros que se ejecutan dentro de contenedores Linux DEBEN
# conservar saltos de línea LF: un .sh con CRLF rompe en Linux ("/bin/sh: bad interpreter: ^M").
# Esto blinda el despliegue Docker frente a checkouts en Windows (core.autocrlf=true).
*.sh        text eol=lf
entrypoint.sh text eol=lf
Dockerfile  text eol=lf
*.Dockerfile text eol=lf
